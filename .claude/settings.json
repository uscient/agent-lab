{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git tag:*)",
      "Bash(gh pr:*)",
      "Bash(rm -rf:*)",
      "Bash(sed -i:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(chown -R:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Edit(.claude/**)",
      "Edit(.codex/**)",
      "Edit(.grok/**)",
      "Edit(.devguard/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(secrets/**)",
      "Edit(**/secrets/**)",
      "Write(.env)",
      "Write(secrets/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ],
    "ask": [
      "Edit(**)",
      "Write(**)",
      "Bash(docker compose up:*)",
      "Bash(docker compose run:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose build:*)",
      "Bash(docker build:*)",
      "Bash(./scripts/up:*)",
      "Bash(./scripts/down:*)",
      "Bash(./scripts/egress-test:*)",
      "Bash(./scripts/openclaw-fetch-source:*)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git grep:*)",
      "Bash(docker compose config:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(shellcheck:*)",
      "Bash(./scripts/doctor:*)",
      "Bash(./scripts/check-docker:*)",
      "Bash(./tools/containment-lint.sh:*)",
      "Bash(./tools/validate.sh:*)",
      "Bash(./tools/new-revision.sh:*)",
      "Write(tmp/**)",
      "Edit(tmp/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/tools/pretooluse-guard.sh" } ] }
    ]
  }
}
