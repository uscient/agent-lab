{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(./scripts/dev/:*)",
      "Bash(./scripts/:*)",
      "Bash(./tools/validate.sh:*)",
      "Bash(./tools/containment-lint.sh:*)",
      "Bash(bash tests/:*)",
      "Bash(shellcheck:*)",
      "Bash(bash -n:*)",
      "Bash(docker compose:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git pull:*)",
      "Bash(git pull)",
      "Bash(git merge origin/*)",
      "Bash(git merge upstream/*)",
      "Bash(git rebase origin/*)",
      "Bash(git rebase upstream/*)",
      "Bash(gh pr:*)",
      "Bash(gh pr)",
      "Bash(gh release:*)",
      "Bash(gh release)",
      "Bash(git remote add:*)",
      "Bash(git remote add)",
      "Bash(git remote set-url:*)",
      "Bash(git remote set-url)",
      "Bash(git remote remove:*)",
      "Bash(git remote remove)",
      "Bash(git remote rename:*)",
      "Bash(git remote rename)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/tools/pretooluse-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/tools/pretooluse-guard.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/tools/session-bootstrap.sh\" claude"
          }
        ]
      }
    ]
  }
}
